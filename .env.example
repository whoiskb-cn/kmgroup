# KMGroup 生产管理系统 - 环境变量示例

# 1. 数据库连接
DB_HOST=db
DB_PORT=5432
DB_NAME=kmgroup_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# 2. 应用运行
APP_HOST=0.0.0.0
APP_PORT=2006
APP_DEBUG=true
CORS_ALLOW_ORIGINS=http://localhost:2006,http://127.0.0.1:2006
SESSION_COOKIE_SECURE=false

# 3. 初始化管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SECRET_KEY=CHANGE_ME_SECRET_KEY

# 4. 企业微信
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=
WECHAT_CORP_ID=
WECHAT_SECRET=
WECHAT_AGENT_ID=1000001
WECHAT_PROXY=
WECHAT_ADMIN_USER_IDS=
WECHAT_NORMAL_USER_IDS=
